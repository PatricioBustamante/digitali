{
  "$schema": "https://schemas.dtcg.org/draft/2024-01/dtcg.json",
  "grid": {
    "base":  { "value": "8px",  "type": "dimension" },
    "half":  { "value": "4px",  "type": "dimension" }
  },
  "spacing": {
    "2xs": { "value": "4px",  "type": "dimension", "description": "0.5× sub-grid (icons only)" },
    "xs":  { "value": "8px",  "type": "dimension", "description": "1× grid" },
    "sm":  { "value": "16px", "type": "dimension", "description": "2× grid" },
    "md":  { "value": "24px", "type": "dimension", "description": "3× grid" },
    "lg":  { "value": "32px", "type": "dimension", "description": "4× grid" },
    "xl":  { "value": "40px", "type": "dimension", "description": "5× grid" },
    "2xl": { "value": "48px", "type": "dimension", "description": "6× grid" },
    "3xl": { "value": "56px", "type": "dimension", "description": "7× grid" },
    "4xl": { "value": "64px", "type": "dimension", "description": "8× grid" },
    "5xl": { "value": "80px", "type": "dimension", "description": "10× grid" },
    "6xl": { "value": "96px", "type": "dimension", "description": "12× grid" }
  },
  "typography": {
    "fontSize": {
      "xs":  { "value": "12px", "type": "dimension" },
      "sm":  { "value": "14px", "type": "dimension" },
      "md":  { "value": "16px", "type": "dimension" },
      "lg":  { "value": "18px", "type": "dimension" },
      "xl":  { "value": "20px", "type": "dimension" },
      "2xl": { "value": "24px", "type": "dimension" },
      "3xl": { "value": "32px", "type": "dimension" },
      "4xl": { "value": "40px", "type": "dimension" },
      "5xl": { "value": "48px", "type": "dimension" }
    },
    "lineHeight": {
      "xs":  { "value": "16px", "type": "dimension" },
      "sm":  { "value": "20px", "type": "dimension" },
      "md":  { "value": "24px", "type": "dimension" },
      "lg":  { "value": "28px", "type": "dimension" },
      "xl":  { "value": "32px", "type": "dimension" },
      "2xl": { "value": "40px", "type": "dimension" },
      "3xl": { "value": "48px", "type": "dimension" },
      "4xl": { "value": "56px", "type": "dimension" },
      "5xl": { "value": "64px", "type": "dimension" }
    },
    "letterSpacing": {
      "tight":  { "value": "-0.5px", "type": "dimension" },
      "normal": { "value": "0px",    "type": "dimension" },
      "wide":   { "value": "0.5px",  "type": "dimension" },
      "wider":  { "value": "1px",    "type": "dimension" }
    },
    "fontWeight": {
      "regular":  { "value": 400, "type": "fontWeight" },
      "medium":   { "value": 500, "type": "fontWeight" },
      "semibold": { "value": 600, "type": "fontWeight" },
      "bold":     { "value": 700, "type": "fontWeight" },
      "heavy":    { "value": 800, "type": "fontWeight" }
    }
  },
  "radius": {
    "xs":     { "value": "4px",    "type": "dimension" },
    "sm":     { "value": "8px",    "type": "dimension" },
    "md":     { "value": "16px",   "type": "dimension" },
    "lg":     { "value": "24px",   "type": "dimension" },
    "pill":   { "value": "9999px", "type": "dimension" },
    "circle": { "value": "50%",    "type": "dimension" }
  },
  "components": {
    "button": {
      "height":     { "value": "40px", "type": "dimension" },
      "paddingY":   { "value": "12px", "type": "dimension" },
      "paddingX":   { "value": "16px", "type": "dimension" },
      "radius":     { "value": "{radius.sm}", "type": "dimension" },
      "fontSize":   { "value": "{typography.fontSize.sm}", "type": "dimension" },
      "lineHeight": { "value": "{typography.lineHeight.sm}", "type": "dimension" }
    },
    "card": {
      "padding": { "value": "24px", "type": "dimension" },
      "radius":  { "value": "{radius.sm}", "type": "dimension" },
      "gap":     { "value": "{spacing.sm}", "type": "dimension" }
    },
    "input": {
      "height":   { "value": "40px", "type": "dimension" },
      "paddingY": { "value": "8px",  "type": "dimension" },
      "paddingX": { "value": "12px", "type": "dimension" },
      "radius":   { "value": "{radius.sm}", "type": "dimension" },
      "fontSize": { "value": "{typography.fontSize.md}", "type": "dimension" }
    },
    "badge": {
      "height":   { "value": "24px", "type": "dimension" },
      "paddingY": { "value": "4px",  "type": "dimension" },
      "paddingX": { "value": "8px",  "type": "dimension" },
      "radius":   { "value": "{radius.xs}", "type": "dimension" },
      "fontSize": { "value": "{typography.fontSize.xs}", "type": "dimension" }
    }
  }
}
